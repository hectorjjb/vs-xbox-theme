{
  "_doc": "Visual Studio 2026 theme tokens. Themes use FallbackId to inherit from a built-in Light or Dark theme; we ONLY override what gives our theme its identity. Token set + category GUIDs verified by decoding the built-in Bubblegum theme pkgdef (the canonical tinted-theme reference) — see scripts/decode-pkgdef.mjs and src/reference/. Editor syntax (Text Editor Text Manager Items) still uses the legacy token system in VS 2026.",
  "DecorativeMPF": {
    "_guid": "{0c37665d-8581-4451-8394-6f4d5abd88b1}",
    "_doc": "Fluent decorative palette — named tints used directly by some chrome (notably the Extension Manager pivot underline = LavenderPrimaryAlt). Overriding the Lavender family redirects all 'this UI uses lavender' surfaces to the flavor's green. We don't override Red/Orange/Yellow/Teal/Blue/Grape/Grey because they're semantic (errors, warnings, info, etc.) and recoloring them would break VS's information design.",
    "LavenderPrimary":     { "background": "$green" },
    "LavenderPrimaryAlt":  { "background": "$greenBright" },
    "LavenderSecondary":   { "background": "$green:cc" },
    "LavenderTertiary":    { "background": "$green:99" },
    "LavenderQuaternary":  { "background": "$green:66" },
    "LavenderQuinary":     { "background": "$green:33" },
    "LavenderSenary":      { "background": "$green:1f" },
    "LightPurplePrimary":     { "background": "$green" },
    "LightPurplePrimaryAlt":  { "background": "$greenBright" },
    "LightPurpleSecondary":   { "background": "$green:cc" },
    "LightPurpleTertiary":    { "background": "$green:99" },
    "LightPurpleQuaternary":  { "background": "$green:66" },
    "LightPurpleQuinary":     { "background": "$green:33" },
    "LightPurpleSenary":      { "background": "$green:1f" },
    "PurplePrimary":     { "background": "$green" },
    "PurplePrimaryAlt":  { "background": "$greenBright" },
    "PurpleSecondary":   { "background": "$green:cc" },
    "PurpleTertiary":    { "background": "$green:99" },
    "PurpleQuaternary":  { "background": "$green:66" },
    "PurpleQuinary":     { "background": "$green:33" },
    "PurpleSenary":      { "background": "$green:1f" }
  },
  "Shell": {
    "_guid": "{73708ded-2d56-4aad-b8eb-73b20d3f4bff}",
    "_doc": "Modern Shell category — accent + base surface tokens. Pattern from built-in Bubblegum, expanded to cover the full accent family (Alt, Text*, Senary, SelectedText*) so that pivot/tab underlines, focused links, and accent-tinted UI all pick up the flavor's green instead of the fallback theme's purple/blue.",
    "AccentFillDefault":                       { "background": "$green" },
    "AccentFillSecondary":                     { "background": "$green:e5" },
    "AccentFillTertiary":                      { "background": "$green:cc" },
    "AccentFillAlt":                           { "background": "$greenBright" },
    "AccentFillDisabled":                      { "background": "$fg:28" },
    "AccentFillSenary":                        { "background": "$green:1f" },
    "AccentFillSelectedTextBackground":        { "background": "$green" },
    "AccentFillSelectedTextBackgroundSubtle":  { "background": "$green:66" },
    "AccentTextFillPrimary":                   { "background": "$greenBright" },
    "AccentTextFillSecondary":                 { "background": "$greenBright" },
    "AccentTextFillTertiary":                  { "background": "$green" },
    "AccentTextFillDisabled":                  { "background": "$fg:5d" },
    "TextOnAccentFillPrimary":                 { "background": "$accentFg" },
    "TextOnAccentFillSecondary":               { "background": "$accentFg:80" },
    "TextOnAccentFillSelectedText":            { "background": "$accentFg" },
    "TextOnAccentFillDisabled":                { "background": "$accentFg:80" },
    "SolidBackgroundFillTertiary":             { "background": "$bg" },
    "SolidBackgroundFillQuaternary":           { "background": "$bgAlt" },
    "SurfaceBackgroundFillDefault":            { "background": "$bg" },
    "TextFillSecondary":                       { "background": "$fg:b2" }
  },
  "ShellInternal": {
    "_guid": "{5af241b7-5627-4d12-bfb1-2b67d11127d7}",
    "_doc": "ShellInternal — covers the most-visible chrome surfaces. 10 tokens matching Bubblegum's pattern: EnvironmentBody is the main backdrop; Header/Tab(/Inactive) drive title bar + tab strip; Border + Logo + Indicator carry the accent.",
    "EnvironmentBackground":        { "background": "$bgDeep" },
    "EnvironmentBody":              { "background": "$bg" },
    "EnvironmentBorder":            { "background": "$green" },
    "EnvironmentHeader":            { "background": "$bgDeep" },
    "EnvironmentHeaderInactive":    { "background": "$bgDeeper" },
    "EnvironmentIndicator":         { "background": "$green:80" },
    "EnvironmentLayeredBackground": { "background": "$fg:10" },
    "EnvironmentLogo":              { "background": "$green" },
    "EnvironmentTab":               { "background": "$bgDeep" },
    "EnvironmentTabInactive":       { "background": "$bgDeeper" }
  },
  "Text Editor Text Manager Items": {
    "_guid": "{75a05685-00a8-4ded-bae5-e7a50bfa929a}",
    "_doc": "Editor syntax colors. Editor still uses legacy tokens per VS 2026 docs FAQ.",
    "Plain Text":              { "background": "$bg",       "foreground": "$fg" },
    "Selected Text":           { "background": "$alphaMed" },
    "Indicator Margin":        { "background": "$bgDeep" },
    "Line Number":             { "background": "$bg",       "foreground": "$fgDimmer" },
    "Visible Whitespace":      { "foreground": "$fgDimmer" },
    "Comment":                 { "foreground": "$fgDim" },
    "Keyword":                 { "foreground": "$green" },
    "String":                  { "foreground": "$yellowSoft" },
    "Number":                  { "foreground": "$purple" },
    "Operator":                { "foreground": "$red" },
    "Identifier":              { "foreground": "$fg" },
    "User Types":              { "foreground": "$blue" },
    "User Members":            { "foreground": "$lightBlue" },
    "Preprocessor Keyword":    { "foreground": "$orangeBright" }
  }
}

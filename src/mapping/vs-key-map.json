{
  "_doc": "Visual Studio 2026 theme tokens. Themes use FallbackId to inherit from a built-in Light or Dark theme; we ONLY override what gives our theme its identity. Token set + category GUIDs verified by decoding the built-in Bubblegum theme pkgdef (the canonical tinted-theme reference) — see scripts/decode-pkgdef.mjs and src/reference/. Editor syntax (Text Editor Text Manager Items) still uses the legacy token system in VS 2026.",
  "DecorativeMPF": {
    "_guid": "{0c37665d-8581-4451-8394-6f4d5abd88b1}",
    "_doc": "Fluent decorative palette — named tints used directly by some chrome (notably the Extension Manager pivot underline = LavenderPrimaryAlt). Overriding the Lavender family redirects all 'this UI uses lavender' surfaces to the flavor's green. We don't override Red/Orange/Yellow/Teal/Blue/Grape/Grey because they're semantic (errors, warnings, info, etc.) and recoloring them would break VS's information design.",
    "LavenderPrimary":     { "background": "$green" },
    "LavenderPrimaryAlt":  { "background": "$greenBright" },
    "LavenderSecondary":   { "background": "$green:cc" },
    "LavenderTertiary":    { "background": "$green:99" },
    "LavenderQuaternary":  { "background": "$green:66" },
    "LavenderQuinary":     { "background": "$green:33" },
    "LavenderSenary":      { "background": "$green:1f" },
    "LightPurplePrimary":     { "background": "$green" },
    "LightPurplePrimaryAlt":  { "background": "$greenBright" },
    "LightPurpleSecondary":   { "background": "$green:cc" },
    "LightPurpleTertiary":    { "background": "$green:99" },
    "LightPurpleQuaternary":  { "background": "$green:66" },
    "LightPurpleQuinary":     { "background": "$green:33" },
    "LightPurpleSenary":      { "background": "$green:1f" },
    "PurplePrimary":     { "background": "$green" },
    "PurplePrimaryAlt":  { "background": "$greenBright" },
    "PurpleSecondary":   { "background": "$green:cc" },
    "PurpleTertiary":    { "background": "$green:99" },
    "PurpleQuaternary":  { "background": "$green:66" },
    "PurpleQuinary":     { "background": "$green:33" },
    "PurpleSenary":      { "background": "$green:1f" }
  },
  "Shell": {
    "_guid": "{73708ded-2d56-4aad-b8eb-73b20d3f4bff}",
    "_doc": "Modern Shell category — accent + base surface tokens. Pattern from built-in Bubblegum, expanded to cover the full accent family (Alt, Text*, Senary, SelectedText*) so that pivot/tab underlines, focused links, and accent-tinted UI all pick up the flavor's green instead of the fallback theme's purple/blue.",
    "AccentFillDefault":                       { "background": "$green" },
    "AccentFillSecondary":                     { "background": "$green:e5" },
    "AccentFillTertiary":                      { "background": "$green:cc" },
    "AccentFillAlt":                           { "background": "$greenBright" },
    "AccentFillDisabled":                      { "background": "$fg:28" },
    "AccentFillSenary":                        { "background": "$green:1f" },
    "AccentFillSelectedTextBackground":        { "background": "$green" },
    "AccentFillSelectedTextBackgroundSubtle":  { "background": "$green:66" },
    "AccentTextFillPrimary":                   { "background": "$greenBright" },
    "AccentTextFillSecondary":                 { "background": "$greenBright" },
    "AccentTextFillTertiary":                  { "background": "$green" },
    "AccentTextFillDisabled":                  { "background": "$fg:5d" },
    "TextOnAccentFillPrimary":                 { "background": "$accentFg" },
    "TextOnAccentFillSecondary":               { "background": "$accentFg:80" },
    "TextOnAccentFillSelectedText":            { "background": "$accentFg" },
    "TextOnAccentFillDisabled":                { "background": "$accentFg:80" },
    "SolidBackgroundFillTertiary":             { "background": "$bg" },
    "SolidBackgroundFillQuaternary":           { "background": "$bgAlt" },
    "SurfaceBackgroundFillDefault":            { "background": "$bg" },
    "TextFillSecondary":                       { "background": "$fg:b2" }
  },
  "TreeView": {
    "_guid": "{92ecf08e-8b13-4cf4-99e9-ae2692382185}",
    "_doc": "Solution Explorer / Test Explorer / any WPF TreeView tool window. Recolors row selection (active + inactive), expand-chevron glyph, drag-over indicator, and search-result highlight to the flavor green. Does NOT change folder/file icon glyphs themselves — those are SVG monikers owned by the project system (would require a separate image-asset extension).",
    "SelectedItemActive":                  { "background": "$green:cc", "foreground": "$accentFg" },
    "SelectedItemActiveGlyph":             { "background": "$accentFg" },
    "SelectedItemActiveGlyphMouseOver":    { "background": "$accentFg" },
    "SelectedItemInactive":                { "background": "$green:55", "foreground": "$fg" },
    "SelectedItemInactiveGlyph":           { "background": "$fg" },
    "SelectedItemInactiveGlyphMouseOver":  { "background": "$greenBright" },
    "Glyph":                               { "background": "$fg:99" },
    "GlyphMouseOver":                      { "background": "$greenBright" },
    "DragOverItem":                        { "background": "$green:66", "foreground": "$accentFg" },
    "DragOverItemGlyph":                   { "background": "$accentFg" },
    "DragOverItemGlyphMouseOver":          { "background": "$accentFg" },
    "HighlightedSpan":                     { "background": "$green", "foreground": "$accentFg" },
    "FocusVisualBorder":                   { "background": "$green" },
    "ItemAdornment":                       { "foreground": "$greenBright" }
  },
  "ShellInternal": {
    "_guid": "{5af241b7-5627-4d12-bfb1-2b67d11127d7}",
    "_doc": "ShellInternal — covers the most-visible chrome surfaces. 10 tokens matching Bubblegum's pattern: EnvironmentBody is the main backdrop; Header/Tab(/Inactive) drive title bar + tab strip; Border + Logo + Indicator carry the accent.",
    "EnvironmentBackground":        { "background": "$bgDeep" },
    "EnvironmentBody":              { "background": "$bg" },
    "EnvironmentBorder":            { "background": "$green" },
    "EnvironmentHeader":            { "background": "$bgDeep" },
    "EnvironmentHeaderInactive":    { "background": "$bgDeeper" },
    "EnvironmentIndicator":         { "background": "$green:80" },
    "EnvironmentLayeredBackground": { "background": "$fg:10" },
    "EnvironmentLogo":              { "background": "$green" },
    "EnvironmentTab":               { "background": "$bgDeep" },
    "EnvironmentTabInactive":       { "background": "$bgDeeper" }
  },
  "Text Editor Text Manager Items": {
    "_guid": "{58e96763-1d3b-4e05-b6ba-ff7115fd0b7b}",
    "_doc": "Editor base surface. Only 5 tokens live in this category — Plain Text (editor canvas), Selected Text + variants, and Indicator Margin (the breakpoint gutter strip). Syntax tokens live in Text Editor MEF Items / Language Service Items, not here. GUID verified by decoding EditorColors.pkgdef.",
    "Plain Text":                       { "background": "$bg",       "foreground": "$fg" },
    "Selected Text":                    { "background": "$alphaMed" },
    "Inactive Selected Text":           { "background": "$alphaLow" },
    "Selected Text in High Contrast":   { "background": "$green:55" },
    "Indicator Margin":                 { "background": "$bgDeep" }
  },
  "Text Editor MEF Items": {
    "_guid": "{75a05685-00a8-4ded-bae5-e7a50bfa929a}",
    "_doc": "Modern (MEF) editor classifications. Holds syntax (Keyword/Comment/String/etc.), gutter (Line Number), rainbow brackets (brace pair level *), inline diff/merge tints, Peek view chrome, breakpoint glyph fills, Current Statement highlight, reference highlights. Roslyn + most language services emit through this category. Shares its GUID with Text Editor Text Manager Items but VS routes by category NAME, so the two coexist as distinct token sets.",
    "Keyword":                                                     { "foreground": "$green" },
    "Comment":                                                     { "foreground": "$fgDim" },
    "Identifier":                                                  { "foreground": "$fg" },
    "String":                                                      { "foreground": "$yellowSoft" },
    "Number":                                                      { "foreground": "$purple" },
    "Operator":                                                    { "foreground": "$red" },
    "Preprocessor Keyword":                                        { "foreground": "$orangeBright" },
    "XML Doc Comment":                                             { "foreground": "$fgDim" },
    "XML Doc Tag":                                                 { "foreground": "$blueDeep" },
    "Line Number":                                                 { "background": "$bg",       "foreground": "$fgDimmer" },
    "Selected Line Number":                                        { "background": "$bg",       "foreground": "$green" },
    "brace pair level one":                                        { "foreground": "$green" },
    "brace pair level two":                                        { "foreground": "$blue" },
    "brace pair level three":                                      { "foreground": "$yellow" },
    "mismatched brace":                                            { "foreground": "$red" },
    "hinted suggestion":                                           { "foreground": "$fgDimmer" },
    "Current Statement":                                           { "background": "$yellow:33" },
    "Current Statement (new context)":                             { "background": "$green:33" },
    "Current Statement (historical mode)":                         { "background": "$alphaLow" },
    "Expression Hover Highlight":                                  { "background": "$alphaLow" },
    "deltadiff.add.word":                                          { "background": "$green:33" },
    "deltadiff.remove.word":                                       { "background": "$red:33" },
    "mergeEditor.AcceptedLine":                                    { "background": "$green:1f" },
    "mergeEditor.AcceptedSimilarLine":                             { "background": "$green:14" },
    "mergeEditor.ConflictLine":                                    { "background": "$red:1f" },
    "mergeEditor.ConflictMismatchLine":                            { "background": "$red:14" },
    "mergeEditor.NotAcceptedLine":                                 { "background": "$orange:1f" },
    "mergeEditor.MarginIndicator":                                 { "background": "$green" },
    "mergeEditor.ConflictMarginIndicator":                         { "background": "$red" },
    "Peek Background":                                             { "background": "$bgDeep" },
    "Peek Background Unfocused":                                   { "background": "$bgDeeper" },
    "Peek Label Text":                                             { "background": "$bgDeep", "foreground": "$fg" },
    "Suggestion Margin":                                           { "background": "$bgDeep" },
    "Inline Rename Field Text":                                    { "background": "$green:33", "foreground": "$fg" },
    "MarkerFormatDefinition/HighlightedReference":                 { "background": "$alphaMed" },
    "MarkerFormatDefinition/HighlightedDefinition":                { "background": "$green:33" },
    "MarkerFormatDefinition/HighlightedWrittenReference":          { "background": "$orange:33" },
    "Breakpoint (Enabled)":                                        { "background": "$red", "foreground": "$accentFg" },
    "Breakpoint (Disabled)":                                       { "background": "$red:80", "foreground": "$accentFg" },
    "Breakpoint (Error)":                                          { "background": "$orangeBright", "foreground": "$accentFg" },
    "Breakpoint (Warning)":                                        { "background": "$yellow", "foreground": "$accentFg" },
    "Breakpoint - Advanced (Enabled)":                             { "background": "$red", "foreground": "$accentFg" },
    "Breakpoint - Temporary (Enabled)":                            { "background": "$red:cc", "foreground": "$accentFg" },
    "Breakpoint - Selected":                                       { "background": "$green", "foreground": "$accentFg" }
  },
  "Text Editor Language Service Items": {
    "_guid": "{e0187991-b458-4f7e-8ca9-42c9a573b56c}",
    "_doc": "Legacy language-service classifications. Many language services still emit through this category (especially the User Types(*) variants for C# value types, interfaces, delegates, enums, type parameters). Syntax token names duplicated from MEF Items so VS finds the color regardless of which classifier fires.",
    "Keyword":                       { "foreground": "$green" },
    "Comment":                       { "foreground": "$fgDim" },
    "Identifier":                    { "foreground": "$fg" },
    "String":                        { "foreground": "$yellowSoft" },
    "Operator":                      { "foreground": "$red" },
    "Preprocessor Keyword":          { "foreground": "$orangeBright" },
    "User Types":                    { "foreground": "$blue" },
    "User Types(Value types)":       { "foreground": "$blue" },
    "User Types(Interfaces)":        { "foreground": "$lightBlue" },
    "User Types(Delegates)":         { "foreground": "$blueDeep" },
    "User Types(Enums)":             { "foreground": "$blue" },
    "User Types(Type parameters)":   { "foreground": "$lightBlue" },
    "String(C# @ Verbatim)":         { "foreground": "$yellowSoft" },
    "XML Comment":                   { "foreground": "$fgDim" },
    "XAML Keyword":                  { "foreground": "$green" },
    "XAML Comment":                  { "foreground": "$fgDim" },
    "XML Keyword":                   { "foreground": "$green" },
    "XSLT Keyword":                  { "foreground": "$green" }
  },
  "Text Editor Text Marker Items": {
    "_guid": "{ff349800-ea43-46c1-8c98-878e78f46501}",
    "_doc": "Marker/squiggle layer — compiler errors/warnings, snippet fields, definition-window background, edit-and-continue highlight. Foreground here colors the squiggle/underline; background colors the strip.",
    "compiler error":                  { "foreground": "$red" },
    "syntax error":                    { "foreground": "$red" },
    "other error":                     { "foreground": "$red" },
    "compiler warning":                { "foreground": "$yellow" },
    "information":                     { "foreground": "$blue" },
    "hinted suggestion":               { "foreground": "$fgDimmer" },
    "Edit and Continue":               { "background": "$orange:33" },
    "Definition Window Background":    { "background": "$bgDeep" },
    "Code Snippet Field":              { "background": "$green:33", "foreground": "$fg" },
    "Code Snippet Field (Selected)":   { "background": "$green:55", "foreground": "$fg" },
    "Code Snippet Dependent Field":    { "background": "$green:1f", "foreground": "$fg" }
  },
  "Output Window": {
    "_guid": "{9973efdf-317d-431c-8bc1-5e88cbfd4f7f}",
    "_doc": "Output tool window (Build/Debug/General). Without overriding this, build output keeps the fallback theme's beige/grey backdrop while the editor goes Xbox-green. OutputError/OutputHeading/OutputVerbose color the colored runs MSBuild + the debugger emit.",
    "Plain Text":           { "background": "$bgDeep", "foreground": "$fg" },
    "Selected Text":        { "background": "$alphaMed", "foreground": "$fg" },
    "Inactive Selected Text": { "background": "$alphaLow", "foreground": "$fg" },
    "OutputError":          { "foreground": "$red" },
    "OutputHeading":        { "foreground": "$green" },
    "OutputVerbose":        { "foreground": "$fgDim" }
  },
  "Find Results": {
    "_guid": "{5c48b2cb-0366-4fbf-9786-0bb37e945687}",
    "_doc": "Find in Files results window. Plain Text = backdrop; Current List Location = the selected result row; Selected Text = mouse selection inside a result line.",
    "Plain Text":              { "background": "$bg", "foreground": "$fg" },
    "Selected Text":           { "background": "$alphaMed", "foreground": "$fg" },
    "Inactive Selected Text":  { "background": "$alphaLow", "foreground": "$fg" },
    "Current List Location":   { "background": "$green:55", "foreground": "$accentFg" }
  },
  "Editor Tooltip": {
    "_guid": "{a9a5637f-b2a8-422e-8fb5-dfb4625f0111}",
    "_doc": "Hover tooltip (QuickInfo) backdrop. Without this override, hovers fall back to the parent theme's grey panel and stand out against the flavor backdrop.",
    "Plain Text": { "background": "$bgAlt", "foreground": "$fg" }
  },
  "CodeSense": {
    "_guid": "{fc88969a-cbed-4940-8f48-142a503e2381}",
    "_doc": "CodeLens — the inline 'N references' / git-blame / test-status indicators above each method. fg = the muted lens text; selected/hover tint up to the accent.",
    "IndicatorText":          { "foreground": "$fgDim" },
    "IndicatorTextHovered":   { "foreground": "$greenBright" },
    "IndicatorTextSelected":  { "foreground": "$green" },
    "IndicatorTextDisabled":  { "foreground": "$fgDimmer" },
    "IndicatorSeparator":     { "foreground": "$alphaLow" }
  }
}
